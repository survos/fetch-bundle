{
    "name": "survos/fetch-bundle",
    "description": "HTTP fetch utilities for Symfony: resumable chunk downloads, caching, retry/backoff, and concurrent fetch into JSONL",
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "symfony/http-client": "^8.1",
        "symfony/console": "^8.1",
        "symfony/messenger": "^8.1",
        "symfony/event-dispatcher": "^8.1",
        "psr/log": "^3.0",
        "symfony/framework-bundle": "^8.1",
        "survos/jsonl-bundle": "^2.6",
        "survos/kit-bundle": "^2.6"
    }
    ,
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Survos\\FetchBundle\\": "src/"
        }
    },
    "prefer-stable": true
}
